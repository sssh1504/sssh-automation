# 帳密設定：此行為註解，# 開頭整行忽略；其餘一行一個 key=value（pin=自然人憑證PIN、sssh_account=校網帳號、sssh_password=校網密碼）
#pin是自然人憑證pin code
pin=000000
#sssh_account是松高校網密碼
sssh_account=abc
sssh_password=abc123
#sssh_publisher是上網公告表單「發布者」欄要填的名稱
sssh_publisher=系管師R
#sssh_publish_unit是上網公告表單「發布單位」下拉要選的單位(擇一,須與站上選項文字一致),如:圖書館/系管師群組/資訊媒體組
sssh_publish_unit=系管師群組
# env_example.env這是個範例，當填入上方的資料後，改名為env.env，記得別把這個檔案push 上github

# ===== 公文總結 LLM backend =====
# summarize_doc.py 依此挑選做公文總結的 LLM。依序嘗試,第一個「可用且成功」的就採用。
# 可用名稱:antigravity / aistudio / claude / anthropic。留空或整行省略 → 用程式預設順序。
summarize_llm_order=antigravity,aistudio,claude,anthropic

# [antigravity] Google Antigravity 的 agy CLI(Google 帳號 OAuth、免費,取代已停用的 gemini CLI)。
#   需先裝 agy 並登入;Python 端需 pywinpty(見 README 安裝)。模型留空=agy 預設(Gemini 系列);
#   要固定填顯示名,如:Gemini 3.5 Flash (Low)
summarize_agy_model=

# [aistudio] Google AI Studio(Gemini)REST API(免裝 SDK)。
#   API key 讀取順序:此處 google_ai_studio_api_key= → 環境變數 GEMINI_API_KEY →
#   ~/.claude/shared-credentials.md 的「Google Gemini API Key」段(機密檔,不放專案內)。
#   一般留空即可(走 shared-credentials.md)。模型留空=gemini-2.5-flash;要固定填如:gemini-2.5-pro
google_ai_studio_api_key=
summarize_aistudio_model=

# [claude] 本機 claude.ai 訂閱(claude -p,免 key、免設定,不需在此填任何東西)。

# [anthropic] Anthropic API key(留空則改讀系統環境變數 ANTHROPIC_API_KEY)。
anthropic_api_key=
